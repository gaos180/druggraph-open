# Copia este archivo como .env y rellena los valores reales.
# NUNCA commits .env al repositorio.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga
DEBUG=True
# En producción: DEBUG=False y ALLOWED_HOSTS=tu-dominio.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=druggraph
# Con autenticación (producción):
# MONGODB_URI=mongodb://druggraph:CAMBIA_ESTO@localhost:27017/

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=druggraph123

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# ── BLAST (opcional — dejar vacío para deshabilitar) ─────────────────────────
BLAST_DB_PATH=
BLAST_MAP_PATH=
BLAST_THREADS=2

# ── Gemini (opcional — reportería IA; sin la key el endpoint devuelve 503) ────
# Obtén una API key en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
