{
  "name": "druggraph-open",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@craco/craco": "7.1.0",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "13.5.0",
    "@types/jest": "27.5.2",
    "@types/node": "16.18.126",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axios": "1.17.0",
    "cytoscape": "3.34.0",
    "lucide-react": "1.21.0",
    "motion": "12.40.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0",
    "react-scripts": "5.0.1",
    "tailwindcss": "4.3.1",
    "typescript": "4.9.5",
    "web-vitals": "2.1.4"
  },
  "scripts": {
    "css": "tailwindcss -i src/styles/notebook.css -o src/styles/notebook.gen.css",
    "css:watch": "tailwindcss -i src/styles/notebook.css -o src/styles/notebook.gen.css --watch",
    "start": "concurrently -k -n css,cra -c blue,green \"npm:css:watch\" \"react-scripts start\"",
    "build": "npm run css -- --minify && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.1",
    "@types/cytoscape": "3.21.9",
    "concurrently": "10.0.3"
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    }
  }
}
