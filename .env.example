# Copia este archivo a .env y ajusta los valores
# cp .env.example .env
#
# OJO: los puertos por defecto corresponden al stack Docker AISLADO de DrugGraph Open
# (docker-compose.yml de este proyecto). No colisionan con un DrugGraph original.

# MongoDB (stack open → puerto 27018)
MONGODB_URI=mongodb://localhost:27018/
MONGODB_DB=druggraph_open

# Neo4j (stack open → Bolt 7688, HTTP 7475)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=druggraphopen123

# PostgreSQL — capa de staging para la ingesta open-source (dumps DrugCentral/ChEMBL).
# Solo lo usan los scripts de scripts/ingest/, no la app en runtime.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=druggraph
POSTGRES_PASSWORD=druggraphopen123
POSTGRES_DB=staging

# Esquema de ID abierto (prefijo del identificador primario derivado de DrugCentral)
OPEN_ID_PREFIX=DC

# JWT — cambia en producción
JWT_SECRET=druggraph-open-jwt-secret-change-in-production

# BLAST (opcional — deja vacío si no usas BLAST search)
BLAST_DB_PATH=
BLAST_MAP_PATH=
BLAST_THREADS=2

# Gemini (reportería IA — opcional). Obtén tu key en https://aistudio.google.com/apikey
# Pon la key real en tu .env local (NUNCA en .env.example, que sí se versiona).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Frontend (opcional — default http://localhost:8000/api)
REACT_APP_API_URL=http://localhost:8000/api
